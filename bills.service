[Unit]
Description=Ford Family Bills
After=network.target

[Service]
Type=simple
User=james
WorkingDirectory=/home/james/bill_tracker
ExecStart=/home/james/bill_tracker/venv/bin/python -m app.main
Restart=on-failure
RestartSec=10
Environment=NTFY_TOPIC=your-topic-here
Environment=ALERT_DAYS_BEFORE=3

[Install]
WantedBy=multi-user.target
